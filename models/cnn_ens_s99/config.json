  "min_learning_rate": 1e-05,
  "gradient_clip_norm": 5.0,
  "augment": true,
  "augmentation_noise_fraction": 0.05,
  "augmentation_scale_min": 0.9,
  "augmentation_scale_max": 1.1,
  "augmentation_flip": false,
  "augmentation_shift_bins": 0,
  "use_batch_norm": false,
  "seed": 99,
  "checkpoint_dir": "models/cnn_v1"
