{
  "n_bins": 201,
  "conv_layers": [
    {
      "out_channels": 16,
      "kernel_size": 5,
      "pool_size": 2
    },
    {
      "out_channels": 32,
      "kernel_size": 5,
      "pool_size": 2
    },
    {
      "out_channels": 64,
      "kernel_size": 3,
      "pool_size": 2
