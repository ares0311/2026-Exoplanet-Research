{
  "version": "background_search_v0",
  "schema_version": "background_search_v0.2",
  "target_pool": "known_tess_examples_v0.2",
  "network_access": false,
  "live_query_mode": false,
  "approval_required_for_external_submission": true,
  "priority_weights": {
    "scientific_interest": 0.22,
    "data_completeness": 0.14,
    "false_positive_risk_inverse": 0.16,
    "follow_up_feasibility": 0.14,
    "calibration_confidence": 0.12,
    "blocking_issue_inverse": 0.12,
    "prior_review_penalty": 0.25,
    "never_reviewed_boost": 0.2
  },
  "thresholds": {
    "follow_up_priority_score": 0.72,
    "low_false_positive_risk": 0.35,
    "calibration_confidence_min": 0.6,
    "blocking_issue_penalty_high": 0.4
  },
  "scheduler": {
    "lock_wait_seconds": 3.0,
    "lock_poll_seconds": 0.1
  },
  "reports": {
    "export_dir": "reports/background",
    "formats": ["markdown", "html"]
  }
}
