# Runtime automation state. Keep the top-level logs directory, not generated DBs.
logs/*.sqlite
logs/*.sqlite3
logs/*.db
logs/*.db-shm
logs/*.db-wal

# Runtime report exports.
reports/background/*.md
reports/background/*.html
